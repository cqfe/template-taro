{
  "name": "template-taro",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.7.1",
  "description": "tarojs + vuejs + nutui模版",
  "templateInfo": {
    "name": "vue3-NutUI",
    "typescript": false,
    "css": "Sass",
    "framework": "Vue3"
  },
  "scripts": {
    "build:wx": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:wx": "npm run build:wx -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "lint": "eslint '**/*.{js,jsx,ts,tsx,vue}' --fix",
    "prepare": "husky"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@nutui/nutui-taro": "4.3.14",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-vue3": "4.2.0",
    "@tarojs/plugin-html": "4.2.0",
    "@tarojs/plugin-http": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-jd": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@vueuse/core": "14.3.0",
    "axios": "1.16.1",
    "dayjs": "^1.11.21",
    "vue": "3.5.34"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@commitlint/config-conventional": "^21.0.1",
    "@cqfe/eslint-config": "^2.0.6",
    "@cqfe/prettier-config": "^2.0.1",
    "@cqfe/stylelint-config": "^2.0.3",
    "@nutui/auto-import-resolver": "^1.0.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "babel-preset-taro": "4.2.0",
    "commitlint": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "sass": "1.76.0",
    "eslint": "^10.4.0",
    "terser": "^5.48.0",
    "unplugin-vue-components": "^32.1.0",
    "webpack": "5.91.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,cjs,mjs}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier -c --write"
    ]
  }
}
